# Copie ce fichier en ".env" et remplis les valeurs réelles.
# Le vrai .env ne doit JAMAIS être commité (il est dans .gitignore).

# Base de données PostgreSQL.
# En local : postgresql://user:motdepasse@localhost:5432/meetingai
# En production (Railway) : fournie automatiquement par la variable DATABASE_URL de Railway.
DATABASE_URL=postgresql://user:password@localhost:5432/meetingai

# Clé secrète pour signer les jetons (mets une longue chaîne aléatoire).
SECRET_KEY=change-moi-par-une-longue-chaine-aleatoire

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Clé API Anthropic (https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Origines autorisées par le CORS en production (URL du frontend déployé).
# Plusieurs URL séparées par des virgules. Laisser vide en local.
FRONTEND_ORIGINS=
